# Option 1: provide a complete SQLAlchemy URL.
# Azure PostgreSQL normally requires sslmode=require.
DATABASE_URL=postgresql+psycopg://db_user:db_password@your-server.postgres.database.azure.com:5432/your_database?sslmode=require

# Option 2: leave DATABASE_URL empty and provide the parts below.
# POSTGRES_HOST=your-server.postgres.database.azure.com
# POSTGRES_PORT=5432
# POSTGRES_DB=your_database
# POSTGRES_USER=db_user
# POSTGRES_PASSWORD=db_password
# POSTGRES_SSLMODE=require

APP_NAME=Agent PostgreSQL API
APP_ENV=development
DEBUG=true
AUTO_CREATE_TABLES=true
