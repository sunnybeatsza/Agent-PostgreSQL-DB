# Option 1: provide a complete SQLAlchemy URL.
# Azure PostgreSQL normally requires sslmode=require.
# DATABASE_URL=postgresql+psycopg://db_user:db_password@your-server.postgres.database.azure.com:5432/your_database?sslmode=require

# Option 2: leave DATABASE_URL empty and provide the parts below.
# POSTGRES_HOST=your-server.postgres.database.azure.com
# POSTGRES_PORT=5432
# POSTGRES_DB=your_database
# POSTGRES_USER=db_user
# POSTGRES_PASSWORD=db_password
# POSTGRES_SSLMODE=require

# Option 3: Azure/PostgreSQL CLI-style variable names are also supported.
# PGHOST=your-server.postgres.database.azure.com
# PGPORT=5432
# PGDATABASE=postgres
# PGUSER=user@example.com
# PGPASSWORD=your_access_token_or_password

# Option 4: Azure PostgreSQL connector/libpq format is also supported.
# You can paste either the raw value or the full pg_connect(...) example.
# POSTGRES_CONNINFO="host=g13hackathon-postgredb.postgres.database.azure.com port=5432 dbname=postgres user=user@example.com password=your_password sslmode=require"
# PGCONNECT_STRING='pg_connect("host=g13hackathon-postgredb.postgres.database.azure.com port=5432 dbname=postgres user=user@example.com password=your_password");'

APP_NAME=Agent PostgreSQL API
APP_ENV=development
DEBUG=true
AUTO_CREATE_TABLES=true
